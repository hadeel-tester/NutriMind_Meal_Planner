# ── OpenAI ──────────────────────────────────────────────────────────────────
# Required. Powers the ReAct agent (gpt-4o-mini) and the format_output node.
OPENAI_API_KEY=

# ── LangSmith observability ─────────────────────────────────────────────────
# Set to "true" to enable LangSmith tracing. LangGraph is auto-instrumented —
# no code changes needed. Set to "false" (or omit) to disable tracing entirely.
LANGCHAIN_TRACING_V2=true

# Your LangSmith API key. Get one at https://smith.langchain.com → Settings.
LANGCHAIN_API_KEY=

# The LangSmith project traces are grouped under. Create the project in the
# LangSmith dashboard first, or it will be created automatically on first run.
LANGCHAIN_PROJECT=meal-planning-agent-sprint3

# ── Persistence ─────────────────────────────────────────────────────────────
# Path (relative to project root) where SQLite stores user health profiles.
MEMORY_DB_PATH=data/user_profiles.db
